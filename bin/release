#!/usr/bin/env bash
set -euo pipefail

BUMP_TYPE="${1:-}"
VERSION_FILE="lib/mdx_tex/version.rb"

if [[ ! "$BUMP_TYPE" =~ ^(patch|minor|major)$ ]]; then
  echo "Usage: bin/release <patch|minor|major>"
  echo ""
  echo "  patch  0.1.8 → 0.1.9"
  echo "  minor  0.1.8 → 0.2.0"
  echo "  major  0.1.8 → 1.0.0"
  exit 1
fi

# Extract current version
CURRENT=$(grep -oP "VERSION = '\K[0-9]+\.[0-9]+\.[0-9]+" "$VERSION_FILE")
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"

case "$BUMP_TYPE" in
  major) MAJOR=$((MAJOR + 1)); MINOR=0; PATCH=0 ;;
  minor) MINOR=$((MINOR + 1)); PATCH=0 ;;
  patch) PATCH=$((PATCH + 1)) ;;
esac

NEW_VERSION="$MAJOR.$MINOR.$PATCH"
TAG="v$NEW_VERSION"

echo "Bumping $CURRENT → $NEW_VERSION"

# Ensure working tree is clean
if [[ -n $(git status --porcelain) ]]; then
  echo "Error: working tree is not clean. Commit or stash changes first."
  exit 1
fi

# Run specs before releasing
echo "Running specs..."
bundle exec rspec

# Update version file
sed -i "s/VERSION = '$CURRENT'/VERSION = '$NEW_VERSION'/" "$VERSION_FILE"

# Commit, tag, and push
git add "$VERSION_FILE"
git commit -m "Release $TAG"
git tag "$TAG"

echo "Pushing to origin..."
git push origin main
git push origin "$TAG"

echo ""
echo "Released $TAG"
echo "GitHub Actions will publish the gem to RubyGems."
